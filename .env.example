# =============================================================================
# PinterestAutomation env template
# Copy to .env and fill in real values. DO NOT commit .env.
# =============================================================================

# -- Runtime -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PINTEREST_SVC_PORT=3001

# -- Postgres (local docker-compose; Railway provides its own DATABASE_URL) --
DATABASE_URL=postgresql://pinterest:pinterest@localhost:5432/pinterest_automation

# -- Pinterest API v5 --------------------------------------------------------
# developer.pinterest.com -> Create app -> get client_id/secret, then OAuth flow
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3001/oauth/pinterest/callback
PINTEREST_REFRESH_TOKEN=

# -- WordPress ---------------------------------------------------------------
# Enable Application Passwords in WP user profile
WORDPRESS_SITE_URL=https://carmens-blog.example.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_SEO_PLUGIN=rankmath # or "yoast"

# -- Anthropic (Claude) ------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-6

# -- OpenAI (optional fallback) ----------------------------------------------
OPENAI_API_KEY=

# -- Ideogram API ------------------------------------------------------------
IDEOGRAM_API_KEY=
IDEOGRAM_NUM_VARIANTS=4

# -- Canva Connect API -------------------------------------------------------
# Enterprise only; start sales conversation early. Fallback plan in project docs.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:3001/oauth/canva/callback
CANVA_TEMPLATE_ID=
CANVA_REFRESH_TOKEN=

# -- Undetectable.ai ---------------------------------------------------------
# Opt-in via HUMANIZE_ENABLED=true
UNDETECTABLE_API_KEY=
HUMANIZE_ENABLED=false

# -- EXIF stripping ---------------------------------------------------------
# Opt-in; default off. Safe to enable for basic metadata removal.
STRIP_EXIF=false

# -- Cloudflare R2 (image blobs) ---------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pinterest-automation
R2_PUBLIC_URL=

# -- Langfuse ---------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3100

# -- Sentry -----------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -- Discord (alerts + mobile fast-path approvals) ---------------------------
DISCORD_BOT_TOKEN=
DISCORD_ALERT_WEBHOOK_URL=
DISCORD_APPROVAL_CHANNEL_ID=

# -- n8n --------------------------------------------------------------------
N8N_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678

# -- Clerk (carmen-web auth) -------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -- carmen-web -> pinterest-svc ---------------------------------------------
NEXT_PUBLIC_PINTEREST_SVC_URL=http://localhost:3001
PINTEREST_SVC_INTERNAL_TOKEN=change_me_shared_secret

# -- Feature flags -----------------------------------------------------------
SCHEDULER_AUTO_POST=false
MONTHLY_IDEOGRAM_SPEND_CAP_USD=60
