# =============================================================================
# PinterestAutomation env template
# Copy to .env and fill in real values. DO NOT commit .env.
# =============================================================================

# -- Runtime -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PINTEREST_SVC_PORT=3001

# -- Postgres (local docker-compose; Railway provides its own DATABASE_URL) --
DATABASE_URL=postgresql://pinterest:pinterest@localhost:5432/pinterest_automation

# -- Pinterest API v5 --------------------------------------------------------
# developer.pinterest.com -> Create app -> get client_id/secret, then OAuth flow
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3001/oauth/pinterest/callback
PINTEREST_REFRESH_TOKEN=

# -- WordPress ---------------------------------------------------------------
# Enable Application Passwords in WP user profile
WORDPRESS_SITE_URL=https://carmens-blog.example.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_SEO_PLUGIN=rankmath # or "yoast"

# -- Anthropic (Claude) ------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-6

# -- Ideogram (image generation) ---------------------------------------------
# ideogram.ai -> API Keys
IDEOGRAM_API_KEY=
MONTHLY_IDEOGRAM_SPEND_CAP_USD=60

# -- Undetectable.ai ---------------------------------------------------------
# Opt-in via HUMANIZE_ENABLED=true
UNDETECTABLE_API_KEY=
HUMANIZE_ENABLED=false

# -- EXIF stripping ---------------------------------------------------------
# Strips all metadata from images before WordPress upload.
STRIP_EXIF=true

# -- Cloudflare R2 (image blobs) ---------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pinterest-automation
R2_PUBLIC_URL=

# -- Langfuse ---------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3100

# -- Sentry -----------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -- Discord (alerts + mobile fast-path approvals) ---------------------------
DISCORD_BOT_TOKEN=
DISCORD_ALERT_WEBHOOK_URL=
DISCORD_APPROVAL_CHANNEL_ID=

# -- Clerk (carmen-web auth) -------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -- carmen-web -> pinterest-svc ---------------------------------------------
NEXT_PUBLIC_PINTEREST_SVC_URL=http://localhost:3001
PINTEREST_SVC_INTERNAL_TOKEN=change_me_shared_secret

# -- Feature flags -----------------------------------------------------------
SCHEDULER_AUTO_POST=false
